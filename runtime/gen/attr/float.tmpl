{{ if not .IsReadOnly }}
w.{{ .StarlarkGoName }} = {{ .StarlarkName }}
if val, ok := starlark.AsFloat(w.{{ .StarlarkGoName }}); ok {
	w.{{ .GoPath }} = val
} else if w.{{ .StarlarkGoName }} != nil {
	return nil, fmt.Errorf("expected number, but got: %s", w.{{ .StarlarkGoName }}.String())
}
