{{ if not .IsReadOnly }}
w.{{ .GoPath }} = slices.Grow(w.{{ .GoPath }}, {{ .StarlarkName }}.Len())
for i, {{ .StarlarkName}}Val := range starlarkutil.Enumerate({{ .StarlarkName }}) {
	if _, isNone := {{ .StarlarkName }}Val.(starlark.NoneType); isNone {
		continue
	}

	{{ .StarlarkName }}Child, ok := {{ .StarlarkName }}Val.({{ .GoWidgetName }})
	if !ok {
		return nil, fmt.Errorf(
			"expected {{ .StarlarkName }} to be a list of Widget but found: %s (at index %d)",
			{{ .StarlarkName }}Val.Type(), i,
		)
	}

	w.{{ .GoPath }} = append(w.{{ .GoPath }}, {{ .StarlarkName }}Child.AsRenderWidget())
}
w.{{ .StarlarkGoName }} = {{ .StarlarkName }}
{{- end }}
