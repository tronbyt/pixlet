{{ if not .IsReadOnly }}
w.starlark{{ .GoName }} = {{ .StarlarkName }}
if {{ .StarlarkName }} != starlark.None {
	c, err := colorutil.Parse({{ .StarlarkName }})
	if err != nil {
		return nil, fmt.Errorf("parsing {{ .StarlarkName }} %s: %w", {{ .StarlarkName }}, err)
	}
	w.{{ .GoPath }} = c
}
{{- end }}
